  "about": {
    "tagline": "Alceix Hakkında",
    "heroTitle": "Kalple Hazırlandı, Yaşam İçin Yapıldı",
    "heroDesc": "Alceix bir lüks mağazadan daha fazlasıdır – bilinçli yaşam için bir destinasyondur. Hayatınızı gerçekten doyumlu hissettirecek yüksek kaliteli, sürdürülebilir ve güzel hazineler sunmak için her parçayı özenle seçiyoruz. Tasarım tutkusu ve detaylara verdiğimiz önemle, hikayenizi yansıtan anlar yaratmanıza yardımcı oluyoruz.",
    "features": {
      "sustainable": "Sürdürülebilir Malzemeler",
      "everyday": "Günlük Yaşam İçin Tasarlandı",
      "expert": "Uzmanlar Tarafından Özenle Hazırlandı",
      "delivery": "Sorunsuz Teslimat ve İade"
    }
