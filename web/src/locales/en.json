  "faq": {
    "title": "Get the Details Before You Decide",
    "subtitle": "Find helpful answers about shipping, returns, care, and everything in between",
    "shipping": {
      "q": "Do you offer free shipping?",
      "a": "Yes, we offer free shipping on orders over {{currencySymbol}}500. For orders below {{currencySymbol}}500, standard shipping rates apply. Express shipping options are available at checkout for an additional fee."
    },
    "return": {
      "q": "Can I return an item if I change my mind?",
      "a": "Absolutely! We offer a 30-day return policy for unused items in their original packaging. Simply contact our customer service team to initiate a return. Return shipping costs may apply."
    },
    "assembly": {
      "q": "Do your products require assembly?",
      "a": "Most of our furniture items require some assembly, but we provide detailed instructions and all necessary tools. Assembly difficulty varies by product, and we clearly indicate this on each product page."
    },
    "care": {
      "q": "How do I care for my furniture?",
      "a": "Care instructions vary by material. We provide specific care guides with each product. Generally, we recommend using appropriate cleaners for wood, fabric, and leather surfaces, and avoiding direct sunlight and excessive moisture."
    },
    "service": {
      "q": "Do you offer assembly services for large furniture items?",
      "a": "Yes, for select regions and products, we offer optional assembly services at checkout. Availability and pricing may vary depending on your location and the item ordered. Check the product page or contact our support team for more details."
    }
  },
