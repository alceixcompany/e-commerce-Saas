  "about": {
    "tagline": "About Alceix",
    "heroTitle": "Crafted with Heart, Made for Living",
    "heroDesc": "Alceix is more than just a luxury store – it's a destination for conscious living. We handpick every piece to offer high-quality, sustainable, and beautiful treasures that make your life truly feel fulfilled. With a passion for design and attention to detail, we help you create moments that reflect your story.",
