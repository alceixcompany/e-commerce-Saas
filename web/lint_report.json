ta/data.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/hooks/useCachedVideo.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/hooks/useTranslation.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/lib/api.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/lib/hooks.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/lib/image-utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/lib/middleware/errorMiddleware.ts","messages":[{"ruleId":null,"message":"Unused eslint-disable directive (no problems were reported from 'no-console').","line":35,"column":5,"severity":1,"nodeType":null,"fix":{"range":[1244,1282],"text":" "}}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":1,"source":"import { isRejectedWithValue, Middleware } from '@reduxjs/toolkit';\nimport { toast } from 'sonner';\n\nexport const errorMiddleware: Middleware = () => (next) => (action) => {\n  if (isRejectedWithValue(action)) {\n\n    const metaArg = (action as { meta?: { arg?: unknown } }).meta?.arg;\n    const isSilent = (() => {\n      if (!metaArg || typeof metaArg !== 'object') return false;\n      const arg = metaArg as Record<string, unknown>;\n      return arg.silent === true || arg.skipToast === true || arg.skipErrorToast === true;\n    })();\n    if (isSilent) {\n      return next(action);\n    }\n\n    const errorMsg = (action.payload as string) || (action.error?.message) || 'An unexpected error occurred';\n    const normalizedError = String(errorMsg).toLowerCase();\n    const isTransientAuthError =\n      normalizedError.includes('401') ||\n      normalizedError.includes('unauthorized') ||\n      normalizedError.includes('jwt expired') ||\n      normalizedError.includes('token expired') ||\n      normalizedError.includes('session expired');\n\n    if (isTransientAuthError) {\n      return next(action);\n    }\n\n    toast.error(errorMsg, {\n      description: 'Please try again or contact support if the issue persists.',\n      duration: 5000,\n    });\n\n    // eslint-disable-next-line no-console\n    console.error(`[Redux Error] ${action.type}:`, errorMsg);\n  }\n\n  return next(action);\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/lib/middleware/requestDebugger.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/lib/redux-utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/lib/services/adminService.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixabl