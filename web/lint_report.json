div>\n                                <label className=\"block text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1\">{t('admin.aboutShowcaseEditor.hoverLabel')}</label>\n                                <input\n                                    type=\"text\"\n                                    className=\"w-full px-3 py-1.5 border border-border rounded-md focus:outline-none focus:border-foreground text-sm\"\n                                    value={settings.imageLabel}\n                                    onChange={(e) => setSettings({ ...settings, imageLabel: e.target.value })}\n                                />\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div className=\"p-6 border-t border-border bg-muted flex justify-end gap-3\">\n                    <button onClick={onClose} className=\"px-6 py-2.5 text-sm font-bold text-muted-foreground hover:text-foreground transition-colors\" disabled={isSaving}>{t('admin.cancel')}</button>\n                    <button onClick={handleSave} disabled={isSaving} className=\"px-6 py-2.5 bg-foreground text-background text-sm font-bold rounded-lg hover:bg-gray-800 transition-colors disabled:opacity-50\">\n                        {isSaving ? t('admin.saving') : t('admin.save')}\n                    </button>\n                </div>\n            </div>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/umid/Documents/GitHub/e-commerce-Saas/web/src/app/admin/layout-settings/_components/Auth/AuthLayoutEditorModal.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'err' is defined but never used.","line":49,"column":18,"nodeType":null,"messageId":"unusedVar","endLine":49,"endColumn":21}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport React, { useState, useEffect } from 'react';\nimport { FiX } from 'react-icons/fi';\nimport { useAppDispatch, useAppSelector } from '@/lib/hooks';\nimport { updateAuthSettings } from '@/lib/slices/contentSlice';\nimport ImageUpload from '@/components/ImageUpload';\nimport { useTranslation } from '@/hooks/useTranslation';\n\ninterface AuthLayoutEditorModalProps {\n    type: 'login' | 'register';\n    onClose: () => void;\n    onUpdate: () => void;\n}\n\nexport default function AuthLayoutEditorModal({ type, onClose, onUpdate }: AuthLayoutEditorModalProps) {\n    const { t } = useTranslation();\n    const dispatch = useAppDispatch();\n    const { authSettings } = useAppSelector((state) => state.content);\n\n    const defaultState = {\n        layout: 'split-left' as const,\n        title: 'Welcome to Alceix',\n        quote: 'Join the Alceix family and discover timeless treasures.',\n        imageUrl: '/image/alceix/hero.png',\n    };\n\n    const initialAuth = authSettings?.[type] || defaultState;\n\n    const [settings, setSettings] = useState(initialAuth);\n    const [isSaving, setIsSaving] = useState(false);\n\n    useEffect(() => {\n        if (authSettings?.[type]) {\n            setSettings(authSettings[type]);\n        }\n    }, [authSettings, type]);\n\n    const handleSave = async () => {\n        if (!authSettings) return;\n        setIsSaving(true);\n        try {\n            await dispatch(updateAuthSettings({\n                ...authSettings,\n                [type]: settings\n            })).unwrap();\n            onUpdate();\n            onClose();\n        } catch (err) {\n            alert(t('admin.saveError'));\n        } finally {\n            setIsSaving(false);\n        }\n    };\n\n    return (\n        <div className=\"fixed inset-0 bg-foreground/50 backdrop-blur-sm z-50 flex items-center justify-center p-4\" onClick={(e) => { if (e.target === e.currentTarget) onClose(); }}>\n            <div className=\"bg-background rounded-2xl w-full max-w-2xl overflow-hidden shadow-2xl animate-in fade-in zoom-in-95 duration-200\">\n                <div className=\"flex items-center justify-between p-6 border-b border-border\">\n                    <div>\n                        <h2 className=\"text-xl font-bold\">\n                            {t('admin.auth.pageLayout', { type: t(`common.${type}`) })}\n                        </h2>\n                        <p className=\"text-xs text-muted-foreground mt-1\">\n                            {t('admin.auth.manageLayout')}\n                        </p>\n                    </div>\n                    <button onClick={onClose} className=\"p-2 hover:bg-muted/80 rounded-full transition-colors\">\n                        <FiX size={20} />\n                    </button>\n                </div>\n\n                <div className=\"p-6 max-h-[70vh] overflow-y-auto\">\n                    {/* Layout Selector */}\n                    <div className=\"pb-6 border-b border-border mb-6\">\n                        <label className=\"block text-xs font-bold text-foreground/80 uppercase tracking-wider mb-4\">\n                            {t('admin.auth.chooseStyle')}\n                        </label>\n                        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n                            {[\n                                {\n                                    id: 'split-left',\n                                    label: t('admin.auth.splitLeft'),\n                                    desc: t('admin.auth.splitLeftDesc'),\n                                    preview: (\n                                        <div className=\"w-full h-20 bg-muted rounded-lg flex gap-2 p-2 border border-border\">\n                                            <div className=\"w-1/2 h-full bg-gray-300 rounded overflow-hidden relative\"></div>\n                                            <div className=\"w-1/2 h-full flex flex-col justify-center gap-1.5 items-center\">\n                                  